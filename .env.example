BBB_PERSONA_ID=
BLAND_FROM_NUMBER=
BLAND_DEFAULT_LANGUAGE=en-US
BLAND_MAX_DURATION_MINUTES=8
BLAND_WAIT_FOR_GREETING=true
BLAND_RECORD_CALLS=true

# SendGrid (Email)
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@betterbusinessbuilder.com

# Buffer (Social Media)
BUFFER_ACCESS_TOKEN=your_buffer_token_here

# OpenAI / Anthropic (Optional Cloud AI)
