# ═══════════════════════════════════════════════════════════════════════
# Better Business Builder (BBB) — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env (or .env.production for Docker Compose) and
# fill in real values.  NEVER commit the .env file to version control.

# ── Application ─────────────────────────────────────────────────────
ENVIRONMENT=production          # production | staging | development | test
SECRET_KEY=CHANGE-ME-TO-A-SECURE-RANDOM-STRING-MIN-32-CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=https://yourdomain.com   # comma-separated allowed origins
LOG_LEVEL=INFO

# ── Database ────────────────────────────────────────────────────────
# For local dev:  sqlite:///./business_builder.db
# For production: postgresql://user:pass@host:5432/bbb_production
DATABASE_URL=sqlite:///./business_builder.db
DATABASE_PASSWORD=CHANGE-ME       # used by Docker Compose for postgres

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=CHANGE-ME          # used by Docker Compose redis auth

# ── Echo / Ollama (Local AI) ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=echo

# ── OpenAI / Anthropic (Cloud AI — optional) ───────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Twilio (SMS & Voice) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15555555555

# ── ElevenLabs (AI Voice) ──────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── SendGrid (Email) ───────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@betterbusinessbuilder.com

# ── Stripe (Payments) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Buffer (Social Media Scheduling) ───────────────────────────────
BUFFER_ACCESS_TOKEN=your_buffer_token_here

# ── Monitoring ──────────────────────────────────────────────────────
GRAFANA_PASSWORD=CHANGE-ME
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE-ME
SENTRY_DSN=                       # optional — Sentry error tracking

# ── Feature Flags ──────────────────────────────────────────────────
AUTONOMOUS_MODE=true              # enable fully autonomous operation
ENABLE_COLD_OUTREACH=false        # enable cold email / calls (review compliance first!)
ENABLE_MARKET_SCANNER=true        # enable daily market opportunity scanning
