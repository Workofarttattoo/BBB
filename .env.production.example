# Better Business Builder - Production Environment Variables
# Copy to .env.production and fill in all values before deploying

# ============================================================
# REQUIRED - Application will not start without these
# ============================================================

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=
JWT_SECRET_KEY=

# PostgreSQL connection
DATABASE_URL=postgresql://bbbuser:CHANGE_ME@postgres:5432/bbb_production

# Redis
REDIS_URL=redis://redis:6379/0

# ============================================================
# PAYMENT PROCESSING (required for revenue features)
# ============================================================
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# AI / LLM (at least one required)
# ============================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Local LLM (alternative to cloud AI)
LLM_PROVIDER=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ech0-fine-tuned-v2:latest
ECH0_LLM_PROVIDER=huggingface
ECH0_LLM_ENDPOINT=https://workofarttattoo-echo-prime-agi.hf.space/api/predict
ECH0_LLM_API_KEY=
ECH0_LLM_TIMEOUT_SECONDS=180
ECHO_BASE_URL=http://echo-prime-service:8001
ECHO_PRIME_BASE_URL=http://echo-prime-service:8001
# Azure Container Apps sets these per service:
# BBB API: APP_MODULE=blank_business_builder.main:app, PORT=8000
# Echo Prime: APP_MODULE=blank_business_builder.echo_prime_api:app, PORT=8001
APP_MODULE=blank_business_builder.main:app
PORT=8000
WEB_CONCURRENCY=4

# ============================================================
# COMMUNICATIONS (optional but recommended)
# ============================================================
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+15555555555

# ============================================================
# SOCIAL MEDIA (optional)
# ============================================================
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_BEARER_TOKEN=
BUFFER_ACCESS_TOKEN=

# ============================================================
# MONITORING (optional)
# ============================================================
SENTRY_DSN=https://xxx@sentry.io/yyy
GRAFANA_PASSWORD=CHANGE_ME

# ============================================================
# CORS (required for web frontend)
# ============================================================
CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
